docker run -it -d \
  --label traefik.http.routers.el-raphapharmacy.rule=Host\(\`el-raphapharmacy.phamasoft.com\`\) \
  --label traefik.http.routers.el-raphapharmacy.tls.certresolver=lets-encrypt \
  --label traefik.http.routers.el-raphapharmacy.tls=true \
  --label traefik.http.routers.el-raphapharmacy.service=el-raphapharmacy-credit-http \
  --label traefik.http.services.el-raphapharmacy-credit-http.loadbalancer.server.port=80 \
  --name el-raphapharmacy \
  --network web \
  --restart always \
  --expose 80 \
  mikoposoft/pharmacyci3:old