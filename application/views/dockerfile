docker run -it -d \
  --label traefik.http.routers.micapharmaceuticals.rule=Host\(\`micapharmaceuticals.phamasoft.com\`\) \
  --label traefik.http.routers.micapharmaceuticals.tls.certresolver=lets-encrypt \
  --label traefik.http.routers.micapharmaceuticals.tls=true \
  --label traefik.http.routers.micapharmaceuticals.service=micapharmaceuticals-credit-http \
  --label traefik.http.services.micapharmaceuticals-credit-http.loadbalancer.server.port=80 \
  --name micapharmaceuticals \
  --network web \
  --restart always \
  --expose 80 \
  mikoposoft/pharmacyci3:old